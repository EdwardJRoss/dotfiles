#!/usr/bin/env bash
set -euo pipefail

# Translate a few Ledger-specific invocations emitted by ledger-mode into
# hledger-compatible commands.

args=("$@")
out=()
date_arg=""

for ((i = 0; i < ${#args[@]}; i++)); do
  case "${args[i]}" in
    --date-format)
      ((i += 1))
      ;;
    cleared)
      out+=("balance" "-N" "-C")
      ;;
    xact)
      out+=("print" "--match")
      ((i += 1))
      date_arg="${args[i]}"
      ;;
    *)
      out+=("${args[i]}")
      ;;
  esac
done

if [[ -n "${date_arg}" ]]; then
  hledger "${out[@]}" | sed "1s/[0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9]/${date_arg}/"
else
  exec hledger "${out[@]}"
fi
